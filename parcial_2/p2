        writer = csv.writer(f)
        writer.writerow(["op_index", "job", "op_idx", "machine", "p", "start", "end"])
        for i, op in enumerate(scheduled_ops, 1):
            writer.writerow([i, op.job, op.op_idx+1, op.machine, op.p, op.start, op.end])
    print("\nSe exportó 'schedule_ops.csv' con los detalles de las operaciones.")
except Exception:
    pass