Takt Time requerido: {resultado['takt_time']:.2f} segundos/unidad
Estaciones necesarias: {resultado['n_estaciones']}
Tiempo de ciclo logrado: {resultado['ciclo_real']:.2f} segundos/unidad
Producción: {resultado['produccion']:,.0f} unidades/mes
Demanda requerida: {demanda_total:,} unidades/mes
¿Cumple con la demanda? {'SÍ' if resultado['produccion'] >= demanda_total else 'NO'}
Eficiencia: {resultado['eficiencia']:.1%}

Asignación óptima:
"""
            for i, (estacion, tiempo) in enumerate(zip(resultado['asignacion'], resultado['tiempos_estacion'])):
                texto_resultado += f"- Estación {i+1}: {estacion} → {tiempo:.2f} segundos\n"

            texto_resultado += f"""
Interpretación:
El balanceo óptimo requiere {resultado['n_estaciones']} estaciones de trabajo para 
cumplir con la demanda de {demanda_total:,} unidades mensuales.

La eficiencia de {resultado['eficiencia']:.1%} indica {'un excelente balance' if resultado['eficiencia'] > 0.85 
else 'un balance aceptable' if resultado['eficiencia'] > 0.7 else 'oportunidades de mejora'} 
en la distribución del trabajo.

El tiempo de ciclo de {resultado['ciclo_real']:.2f} segundos es {'menor' if resultado['ciclo_real'] < resultado['takt_time'] 
else 'mayor'} que el takt time requerido de {resultado['takt_time']:.2f} segundos.
"""
        else:
            texto_resultado = "No se encontró una solución óptima que cumpla con la demanda requerida."

        text_widget = scrolledtext.ScrolledText(texto_frame, wrap=tk.WORD, width=60, height=20)
        text_widget.pack(fill='both', expand=True)
        text_widget.insert(tk.END, texto_resultado)
        text_widget.config(state=tk.DISABLED)
        
        # Gráfica de balanceo óptimo
        if resultado:
            grafica_frame = ttk.Frame(resultados_frame)
            grafica_frame.pack(fill='both', expand=True, side='right')
            
            fig = Figure(figsize=(8, 6))
            ax = fig.add_subplot(111)
            
            estaciones = [f'Estación {i+1}' for i in range(resultado['n_estaciones'])]
            tiempos = resultado['tiempos_estacion']
            
            bars = ax.bar(estaciones, tiempos, color='lightgreen', edgecolor='darkgreen', alpha=0.7)
            ax.axhline(y=resultado['ciclo_real'], color='red', linestyle='--', 
                      label=f'Tiempo de Ciclo: {resultado["ciclo_real"]:.2f}s')
            ax.axhline(y=resultado['takt_time'], color='blue', linestyle=':', 
                      label=f'Takt Time: {resultado["takt_time"]:.2f}s')
            
            ax.set_xlabel('Estaciones de Trabajo')
            ax.set_ylabel('Tiempo (segundos)')
            ax.set_title('Balanceo Óptimo - Distribución de Tiempos', fontweight='bold')
            ax.legend()
            ax.grid(True, alpha=0.3)
            
            # Añadir valores en las barras
            for bar, tiempo in zip(bars, tiempos):
                height = bar.get_height()
                ax.text(bar.get_x() + bar.get_width()/2., height + 0.5,
                       f'{tiempo:.2f}s', ha='center', va='bottom')
            
            canvas = FigureCanvasTkAgg(fig, grafica_frame)
            canvas.draw()
            canvas.get_tk_widget().pack(fill='both', expand=True)
    
    def crear_tab_datos(self):
        main_frame = ttk.Frame(self.tab_datos, padding="10")
        main_frame.pack(fill='both', expand=True)
        
        ttk.Label(main_frame, text="MODIFICAR DATOS DEL EJERCICIO", 
                 font=("Arial", 14, "bold")).pack(pady=10)
        
        # Información
        info_frame = ttk.LabelFrame(main_frame, text="Instrucciones", padding="10")
        info_frame.pack(fill='x', padx=10, pady=10)
        
        texto_info = """
Para modificar los datos:
1. Cambie los valores en la tabla (doble clic en cualquier celda)
2. Haga clic en "Guardar Cambios"
3. Los resultados se actualizarán automáticamente en todas las pestañas
        """
        ttk.Label(info_frame, text=texto_info, justify='left').pack(anchor='w')
        
        # Tabla de tiempos
        tabla_frame = ttk.LabelFrame(main_frame, text="Tabla de Tiempos (segundos)", padding="10")
        tabla_frame.pack(fill='both', expand=True, padx=10, pady=10)
        
        # Crear Treeview
        columns = ['Tarea', 'K6', 'UK', 'KZ', 'K_Premium', 'Compuesto']
        tree = ttk.Treeview(tabla_frame, columns=columns, show='headings', height=12)
        
        for col in columns:
            tree.heading(col, text=col)
            tree.column(col, width=80)
        
        # Insertar datos
        for tarea, datos in self.balanceador.tabla_tiempos.items():
            tree.insert('', 'end', values=(
                tarea, 
                datos['K6'], 
                datos['UK'], 
                datos['KZ'], 
                datos['K_Premium'], 
                datos['Compuesto']
            ))
        
        tree.pack(fill='both', expand=True)
        
        # Botones
        botones_frame = ttk.Frame(main_frame)
        botones_frame.pack(fill='x', padx=10, pady=10)
        
        ttk.Button(botones_frame, text="Actualizar Todas las Pestañas", 
                  command=self.actualizar_todas_pestanas).pack(side='left', padx=5)


    def actualizar_todas_pestanas(self):
        # Actualizar todas las pestañas
        self.crear_tab_punto_a()
        self.crear_tab_punto_b()
        self.crear_tab_punto_c()
        self.crear_tab_punto_d()
        self.crear_tab_punto_e()
        
        messagebox.showinfo("Éxito", "Todas las pestañas han sido actualizadas con los nuevos datos")


