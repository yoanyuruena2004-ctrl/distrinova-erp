    def crear_tab_punto_a(self):
        main_frame = ttk.Frame(self.tab_punto_a, padding="10")
        main_frame.pack(fill='both', expand=True)
        
        ttk.Label(main_frame, text="a) DIAGRAMA DE RED DE OPERACIONES", 
                 font=("Arial", 14, "bold")).pack(pady=10)
        
        # Crear diagrama de red
        G = self.balanceador.crear_diagrama_red()
        
        # Crear figura
        fig = Figure(figsize=(10, 8))
        ax = fig.add_subplot(111)
        
        # Diseñar el layout del grafo
        pos = nx.spring_layout(G, k=3, iterations=50)
        
        # Dibujar nodos
        node_colors = [self.balanceador.tabla_tiempos[node]['Compuesto'] for node in G.nodes()]
        nodes = nx.draw_networkx_nodes(G, pos, node_color=node_colors, 
                                     node_size=1500, cmap=plt.cm.Blues, 
                                     ax=ax, alpha=0.7)
        
        # Dibujar etiquetas de nodos
        labels = {node: f"{node}\n({self.balanceador.tabla_tiempos[node]['Compuesto']}s)" 
                 for node in G.nodes()}
        nx.draw_networkx_labels(G, pos, labels, font_size=8, ax=ax)
        
        # Dibujar aristas
        nx.draw_networkx_edges(G, pos, edge_color='gray', arrows=True, 
                              arrowsize=20, arrowstyle='->', ax=ax)
        
        ax.set_title("Diagrama de Red de Operaciones", fontsize=14, fontweight='bold')
        ax.axis('off')
        
        # Añadir barra de colores
        plt.colorbar(nodes, ax=ax, label='Tiempo Compuesto (segundos)')
        
        # Mostrar en la interfaz
        canvas = FigureCanvasTkAgg(fig, main_frame)
        canvas.draw()
        canvas.get_tk_widget().pack(fill='both', expand=True)
        
        # Información adicional
        info_frame = ttk.LabelFrame(main_frame, text="Información del Diagrama", padding="10")
        info_frame.pack(fill='x', padx=10, pady=10)
        
        texto_info = """
- Cada nodo representa una tarea del proceso
- El número dentro del nodo indica el tiempo compuesto en segundos
- Las flechas indican las relaciones de precedencia entre tareas
- El color indica el tiempo compuesto (azul más oscuro = mayor tiempo)
        """
        ttk.Label(info_frame, text=texto_info, justify='left').pack(anchor='w')
    
