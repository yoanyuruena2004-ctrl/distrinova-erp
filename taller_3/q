class BalanceoLineaCompleto:
    def __init__(self):
        # Datos iniciales
        self.dias_mes = 24
        self.horas_dia = 8
        self.tiempo_disponible = self.dias_mes * self.horas_dia * 3600  # segundos
        
        # Tabla de tiempos según lo solicitado
        self.tabla_tiempos = {
            'A': {'K6': 48, 'UK': 48, 'KZ': 58, 'K_Premium': 62, 'Compuesto': 51},
            'B': {'K6': 30, 'UK': 22, 'KZ': 32, 'K_Premium': 38, 'Compuesto': 28},
            'C': {'K6': 28, 'UK': 18, 'KZ': 24, 'K_Premium': 28, 'Compuesto': 24},
            'D': {'K6': 32, 'UK': 38, 'KZ': 38, 'K_Premium': 32, 'Compuesto': 35},
            'E': {'K6': 26, 'UK': 36, 'KZ': 44, 'K_Premium': 20, 'Compuesto': 32},
            'F': {'K6': 42, 'UK': 42, 'KZ': 28, 'K_Premium': 24, 'Compuesto': 38},
            'G': {'K6': 36, 'UK': 40, 'KZ': 34, 'K_Premium': 30, 'Compuesto': 37},
            'H': {'K6': 0, 'UK': 44, 'KZ': 40, 'K_Premium': 34, 'Compuesto': 25},
            'I': {'K6': 58, 'UK': 62, 'KZ': 48, 'K_Premium': 48, 'Compuesto': 57},
            'J': {'K6': 0, 'UK': 0, 'KZ': 54, 'K_Premium': 52, 'Compuesto': 13},
            'K': {'K6': 0, 'UK': 0, 'KZ': 0, 'K_Premium': 50, 'Compuesto': 5},
            'L': {'K6': 0, 'UK': 0, 'KZ': 0, 'K_Premium': 32, 'Compuesto': 3}
        }
        
        # Demandas iniciales
        self.demandas = {'K6': 4000, 'UK': 3500, 'KZ': 1500, 'K_Premium': 1000}
        
        # Relaciones de precedencia (asumidas)
        self.predecesores = {
            'A': [], 'B': [], 'C': ['A', 'B'], 'D': ['C'], 'E': ['D'], 
            'F': ['D'], 'G': ['E', 'F'], 'H': ['F', 'G'], 'I': ['G', 'H'], 
            'J': ['I'], 'K': ['J'], 'L': ['K']
        }

    # PUNTO b) Coeficientes de demanda
    def calcular_coeficientes_demanda(self):
        demanda_total = sum(self.demandas.values())
        coeficientes = {modelo: demanda/demanda_total for modelo, demanda in self.demandas.items()}
        return coeficientes, demanda_total

    # PUNTO c) Tiempo compuesto
    def calcular_tiempo_compuesto(self):
        tiempos_compuestos = {}
        for tarea, datos in self.tabla_tiempos.items():
            tiempos_compuestos[tarea] = datos['Compuesto']
        return sum(tiempos_compuestos.values()), tiempos_compuestos

    # PUNTO d) Análisis con 4 estaciones
    def analisis_4_estaciones(self, tiempos_compuestos, demanda_total):
        tiempo_total = sum(tiempos_compuestos.values())
        
        # Tiempo de ciclo mínimo teórico
        ciclo_min_teorico = tiempo_total / 4
        
        # Balanceo simple con 4 estaciones
        tareas_ordenadas = sorted(tiempos_compuestos.items(), key=lambda x: x[1], reverse=True)
        
        estaciones = [[], [], [], []]
        tiempos_estacion = [0, 0, 0, 0]
        
        for tarea, tiempo in tareas_ordenadas:
            # Asignar a la estación con menor tiempo
            idx_min = np.argmin(tiempos_estacion)
            estaciones[idx_min].append(tarea)
            tiempos_estacion[idx_min] += tiempo
        
        ciclo_real = max(tiempos_estacion)
        produccion = self.tiempo_disponible / ciclo_real
        eficiencia = tiempo_total / (ciclo_real * 4)
        
        return {
            'ciclo_min_teorico': ciclo_min_teorico,
            'ciclo_real': ciclo_real,
            'produccion': produccion,
            'eficiencia': eficiencia,
            'cumple_demanda': produccion >= demanda_total,
            'asignacion': estaciones,
            'tiempos_estacion': tiempos_estacion
        }

    # PUNTO e) Balanceo óptimo
    def encontrar_balanceo_optimo(self, tiempos_compuestos, demanda_total):
        tiempo_total = sum(tiempos_compuestos.values())
        takt_time = self.tiempo_disponible / demanda_total
        
        # Calcular número mínimo de estaciones
        n_min = int(np.ceil(tiempo_total / takt_time))
        
        # Probar con diferentes números de estaciones
        for n_estaciones in range(n_min, n_min + 5):
            # Balanceo simple
            tareas_ordenadas = sorted(tiempos_compuestos.items(), key=lambda x: x[1], reverse=True)
            estaciones = [[] for _ in range(n_estaciones)]
            tiempos_estacion = [0] * n_estaciones
            
            for tarea, tiempo in tareas_ordenadas:
                idx_min = np.argmin(tiempos_estacion)
                estaciones[idx_min].append(tarea)
                tiempos_estacion[idx_min] += tiempo
            
            ciclo_real = max(tiempos_estacion)
            produccion = self.tiempo_disponible / ciclo_real
            eficiencia = tiempo_total / (ciclo_real * n_estaciones)
            
            if produccion >= demanda_total:
                return {
                    'n_estaciones': n_estaciones,
                    'ciclo_real': ciclo_real,
                    'produccion': produccion,
                    'eficiencia': eficiencia,
                    'asignacion': estaciones,
                    'tiempos_estacion': tiempos_estacion,
                    'takt_time': takt_time
                }
        
        return None

    # PUNTO a) Diagrama de red
    def crear_diagrama_red(self):
        G = nx.DiGraph()
        
        # Añadir nodos con tiempos compuestos
        for tarea in self.tabla_tiempos:
            G.add_node(tarea, tiempo=self.tabla_tiempos[tarea]['Compuesto'])
        
        # Añadir aristas según predecesores
        for tarea, predecesores in self.predecesores.items():
            for pred in predecesores:
                G.add_edge(pred, tarea)
        
        return G


