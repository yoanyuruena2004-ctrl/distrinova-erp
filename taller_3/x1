    def mostrar_graficas(self, tiempos_compuestos, takt_time, resultado, demanda_total):
        # Limpiar frame de gráficas
        for widget in self.frame_graficas.winfo_children():
            widget.destroy()
        
        if not resultado:
            return
        
        # Crear figura con subgráficas
        fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(15, 10))
        
        # Gráfica 1: Tiempos compuestos vs Takt Time
        tareas = list(tiempos_compuestos.keys())
        tiempos = list(tiempos_compuestos.values())
        
        bars1 = ax1.bar(tareas, tiempos, color='lightblue', edgecolor='navy')
        ax1.axhline(y=takt_time, color='red', linestyle='--', linewidth=2, label=f'Takt Time ({takt_time:.1f} s)')
        ax1.set_xlabel('Tareas')
        ax1.set_ylabel('Tiempo (segundos)')
        ax1.set_title('Tiempos Compuestos vs Takt Time')
        ax1.legend()
        ax1.grid(True, alpha=0.3)
        ax1.tick_params(axis='x', rotation=45)
        
        # Añadir valores en las barras
        for bar, tiempo in zip(bars1, tiempos):
            height = bar.get_height()
            ax1.text(bar.get_x() + bar.get_width()/2., height + 1,
                    f'{tiempo:.1f}', ha='center', va='bottom', fontsize=8)
        
        # Gráfica 2: Distribución de tiempos por estación
        estaciones = list(range(1, resultado['estaciones'] + 1))
        tiempos_estacion = resultado['tiempos_estacion']
        
        bars2 = ax2.bar(estaciones, tiempos_estacion, color='lightcoral', edgecolor='darkred')
        ax2.axhline(y=resultado['ciclo_real'], color='red', linestyle='--', 
                   label=f'Tiempo de Ciclo: {resultado["ciclo_real"]:.1f} s')
        ax2.set_xlabel('Estación de Trabajo')
        ax2.set_ylabel('Tiempo (segundos)')
        ax2.set_title('Distribución de Tiempos por Estación')
        ax2.legend()
        ax2.grid(True, alpha=0.3)
        
        # Añadir valores en las barras
        for bar, tiempo in zip(bars2, tiempos_estacion):
            height = bar.get_height()
            ax2.text(bar.get_x() + bar.get_width()/2., height + 1,
                    f'{tiempo:.1f}', ha='center', va='bottom')
        
        # Gráfica 3: Eficiencia del balanceo
        ax3.bar(resultado['estaciones'], resultado['eficiencia'] * 100, 
               color='gold', edgecolor='orange', alpha=0.7, width=0.5)
        ax3.set_xlabel('Número de Estaciones')
        ax3.set_ylabel('Eficiencia (%)')
        ax3.set_title(f'Eficiencia del Balanceo: {resultado["eficiencia"]*100:.1f}%')
        ax3.grid(True, alpha=0.3)
        
        # Gráfica 4: Capacidad vs Demanda
        categorias = ['Demanda Actual', 'Capacidad Producción']
        valores = [demanda_total, resultado['produccion']]
        colores = ['lightgreen' if resultado['produccion'] >= demanda_total else 'lightcoral', 'lightblue']
        
        bars4 = ax4.bar(categorias, valores, color=colores, edgecolor='black')
        ax4.set_ylabel('Unidades por Mes')
        ax4.set_title('Capacidad de Producción vs Demanda')
        ax4.grid(True, alpha=0.3)
        
        # Añadir valores en las barras
        for bar, valor in zip(bars4, valores):
            height = bar.get_height()
            ax4.text(bar.get_x() + bar.get_width()/2., height + 50,
                    f'{valor:,.0f}', ha='center', va='bottom')
        
        plt.tight_layout()
        
        # Mostrar gráfica en la interfaz
        canvas = FigureCanvasTkAgg(fig, self.frame_graficas)
        canvas.draw()
        canvas.get_tk_widget().pack(fill='both', expand=True)

def main():
    root = tk.Tk()
    app = InterfazBalanceoMejorada(root)
    root.mainloop()

if __name__ == "__main__":
